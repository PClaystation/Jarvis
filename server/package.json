{
  "name": "cordyceps-server",
  "version": "0.1.0",
  "private": true,
  "description": "Phone-driven remote command dispatch server",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --test --import tsx test/**/*.test.ts",
    "show-config": "tsx src/tools/showConfig.ts"
  },
  "dependencies": {
    "@fastify/websocket": "^11.2.0",
    "better-sqlite3": "^12.6.2",
    "fastify": "^5.8.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.13.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
